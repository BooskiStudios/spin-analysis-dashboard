# GitHub Pages frontend build that talks to your home Cloudflare-tunnelled server.
# Replace the URL below with your actual Cloudflare Tunnel subdomain once it's set up.
# e.g. https://api.yourdomain.com
VITE_API_BASE_URL=https://competitor-dashboard.bearygoodgames.com

# Keep the correct GitHub Pages base path so assets load
VITE_BASE_PATH=/spin-analysis-dashboard/

